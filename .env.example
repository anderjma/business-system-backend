# Archivo de variables de entorno para Docker Compose (Business System API)
# Copia este archivo como '.env' en esta misma carpeta y define tus valores reales antes de hacer deploy.

# Entorno (Para producción usa 'Production')
ASPNETCORE_ENVIRONMENT=Production

# Clave secreta para firmar los tokens JWT (Debe ser larga y segura)
JWT_SECRET=CambiaEstaClavePorUnaMuySeguraYDeAlMenos32Caracteres!

# Origen permitido para CORS (La URL desde donde se accederá al frontend)
# Ejemplo: https://mi-dominio.com
FRONTEND_URL=http://localhost:5173

# Base de datos en la nube (Opcional - Supabase / Neon / AWS)
# Deja esta variable vacía o comentada si deseas usar el contenedor local 'db' de PostgreSQL.
# DATABASE_URL=Host=aws-0-us-west-1.pooler.supabase.com;Database=postgres;Username=postgres.tu_proyecto;Password=tu_contraseña;Port=5432

# BACKEND_PORT=5000
# DB_PORT=5432
